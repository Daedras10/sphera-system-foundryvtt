<form class="{{cssClass}}" autocomplete="off">
    <header class="sheet-header">
        <img src="{{item.img}}" data-edit="img" title="{{item.name}}" height="64" width="64"/>
        <h1><input name="name" type="text" value="{{item.name}}" placeholder="{{ localize 'Name' }}"/></h1>
    </header>
    <p>Hello, you're a weapon</p>
    <div>
        <table>
            <tr>
                <th>{{localize "sphera.weapon.attackType" }}</th>
                <th>{{localize "sphera.weapon.usageBonus" }}</th>
                <th>{{localize "sphera.weapon.range" }}</th>
                <th>{{localize "sphera.weapon.damageBonus" }}</th>
            </tr>
            <tr>
                <td>
                    <select name="system.attackType">
                        {{selectOptions config.attackTypes selected=system.attackType localize=true}}
                    </select>
                </td>
                <td>
                    {{numberInput system.usageBonus name="system.usageBonus"}}
                </td>
                <td>
                    {{numberInput system.range name="system.range"}}
                </td>
                <td>
                    {{numberInput system.damageBonus name="system.damageBonus"}}
                </td>
            </tr>
        </table>
        {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>
</form>
