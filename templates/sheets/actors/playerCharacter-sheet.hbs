<form class="actor-sheet {{cssClass}}" autocomplete="off">
    {{!-- Sheet Header --}}
    <header class="sheet-header">
        <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
        <h1><input name="system.name" type="text" value="{{actor.name}}" placeholder="{{localize 'sphera.name'}}" data-dtype="String" /></h1>
    </header>
    
    <div class="">
        <h1>Hello ?</h1>
    </div>
    <div class="tab characteristics active" data-group="primary" data-tab="characteristics">
        {{!-- Characteristics Scores --}}
        <div class="grid grid-6col">
            <h1>Tab1 - Characteristics</h1>
            <table>
                <tr>
                    <th colspan="4">{{localize 'sphera.characteristics.reserve.title'}}</th>
                    <th colspan="5">{{localize 'sphera.characteristics.title'}}</th>
                </tr>
                <tr>
                    <th rowspan="2">{{localize 'sphera.characteristics.reserve.physical'}}</th>
                    <td class="reserve-physical-cur" rowspan="2">{{ system.reserve.physical.current }}</td>
                    <td class="reserve-physical-max" rowspan="2">/{{ system.reserve.physical.max }}</td>
                    <td rowspan="2">{{ system.reserve.mental.malus }}</td>
                    
                    <th><a class="roll-attribute" data-attribute="strength">{{ localize 'sphera.characteristics.attributes.strength' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="endurance">{{ localize 'sphera.characteristics.attributes.endurance' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="speed">{{ localize 'sphera.characteristics.attributes.speed' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="agility">{{ localize 'sphera.characteristics.attributes.agility' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="address">{{ localize 'sphera.characteristics.attributes.address' }}</a></th>
                </tr>
                <tr>
                    <td>{{ system.attributes.strength.dices }}D10{{ system.attributes.strength.text }}</td>
                    <td>{{ system.attributes.endurance.dices }}D10{{ system.attributes.endurance.text }}</td>
                    <td>{{ system.attributes.speed.dices }}D10{{ system.attributes.speed.text }}</td>
                    <td>{{ system.attributes.agility.dices }}D10{{ system.attributes.agility.text }}</td>
                    <td>{{ system.attributes.address.dices }}D10{{ system.attributes.address.text }}</td>
                </tr>
                <tr>
                    <th rowspan="2">{{localize 'sphera.characteristics.reserve.mental'}}</th>
                    <td class="reserve-mental-cur" rowspan="2">{{ system.reserve.mental.current }}</td>
                    <td class="reserve-mental-max" rowspan="2">/{{ system.reserve.mental.max }}</td>
                    <td rowspan="2">{{ system.reserve.mental.malus }}</td>

                    <th><a class="roll-attribute" data-attribute="charisma">{{ localize 'sphera.characteristics.attributes.charisma' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="perception">{{ localize 'sphera.characteristics.attributes.perception' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="intellect">{{ localize 'sphera.characteristics.attributes.intellect' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="willpower">{{ localize 'sphera.characteristics.attributes.willpower' }}</a></th>
                    <th><a class="roll-attribute" data-attribute="magic">{{ localize 'sphera.characteristics.attributes.magic' }}</a></th>
                </tr>
                <tr>
                    <td>{{ system.attributes.charisma.dices }}D10{{ system.attributes.charisma.text }}</td>
                    <td>{{ system.attributes.perception.dices }}D10{{ system.attributes.perception.text }}</td>
                    <td>{{ system.attributes.intellect.dices }}D10{{ system.attributes.intellect.text }}</td>
                    <td>{{ system.attributes.willpower.dices }}D10{{ system.attributes.willpower.text }}</td>
                    <td>{{ system.attributes.magic.dices }}D10{{ system.attributes.magic.text }}</td>
                </tr>
            </table>
        </div>
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items active" data-group="primary" data-tab="items">
        <h1>Tab2</h1>
        {{numberInput system.attributes.strength.dices name="system.attributes.strength.dices"}}
        <input type="checkbox" name="system.sheetActions.isEditMode" {{#if system.sheetActions.isEditMode}}checked{{/if}}/>

        {{#if system.sheetActions.isEditMode }}
        <h1>EditMode</h1>
        {{else}}
            <h1>Not EditMode</h1>
        {{/if}}
        <a class="test-roll"><i class="fa fa-dice"></i></a>
    </div>

    



    <section class="items">
        <h3 class="noborder">
            Owned Items rire
            <a class="item-create" data-type="weapon" title="{{ localize "sphera.sheet.actorFunctions.addItem" }}">
                <i class="fa fa-plus"></i>
            </a>
        </h3>
        <ol class="actor-items">
            {{#each actor.items as |item id|}}
                <li class="actor-item" data-item-id="{{item._id}}">
                    <div class="item-name">
                        <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
                        <h4>{{item.name}}</h4>
                    </div>
                    <div class="item-controls">
                        <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                        <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                    </div>
                </li>
            {{/each}}
        </ol>
    </section>
    
</form>